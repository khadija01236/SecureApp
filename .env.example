# =============================================================================
# SecureApp — variables d'environnement
# Copier ce fichier en .env et remplir les valeurs avant de lancer le projet.
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Flask
# -----------------------------------------------------------------------------

# Clé secrète utilisée pour signer les sessions et les tokens (reset password…)
# En production : générer avec `python -c "import secrets; print(secrets.token_hex(32))"`
SECRET_KEY=change-me-in-production

# Environnement Flask : development | production
FLASK_ENV=development

# Nom affiché dans les codes TOTP (application d'authentification)
MFA_ISSUER=SecureApp

# -----------------------------------------------------------------------------
# Base de données PostgreSQL
# -----------------------------------------------------------------------------

# Format : postgresql://<user>:<password>@<host>:<port>/<db>
# En dev Docker : les valeurs ci-dessous correspondent au service "db" du docker-compose
DATABASE_URL=postgresql://flask_user:flask_pass@db:5432/flask_mfa_db

# Identifiants du conteneur PostgreSQL (utilisés par le service "db" dans docker-compose)
# En production : choisir un mot de passe fort
POSTGRES_USER=flask_user
POSTGRES_PASSWORD=flask_pass
POSTGRES_DB=flask_mfa_db

# -----------------------------------------------------------------------------
# Email (Flask-Mail)
# -----------------------------------------------------------------------------

# --- Développement (MailHog) ---
# MailHog est inclus dans docker-compose.yml et capte tous les emails localement.
# Interface web accessible sur http://localhost:8025
MAIL_SERVER=mailhog
MAIL_PORT=1025
MAIL_USE_TLS=false
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@secureapp.local

# --- Production (exemple SMTP externe) ---
# Décommenter et remplir pour utiliser un vrai serveur SMTP
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USE_SSL=false
# MAIL_USERNAME=your-smtp-user
# MAIL_PASSWORD=your-smtp-password
# MAIL_DEFAULT_SENDER=noreply@example.com

# -----------------------------------------------------------------------------
# Gunicorn (production uniquement)
# -----------------------------------------------------------------------------

# Nombre de workers : recommandé = (2 × nombre de CPU) + 1
# Générer avec : python -c "import multiprocessing; print(2 * multiprocessing.cpu_count() + 1)"
GUNICORN_WORKERS=4
