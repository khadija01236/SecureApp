<!--
  Décodeurs custom pour les logs JSON de Flask et Nginx (SecureApp)

  Avec log_format=json dans ossec.conf, Wazuh parse automatiquement tous les
  champs JSON et les rend accessibles comme data.event_type, data.user, data.ip, etc.
  Ces décodeurs servent uniquement à nommer la source (decoded_as) pour les règles.
-->

<!-- Décodeurs nommés pour les logs Flask et Nginx (SecureApp)
     Avec log_format=json, le décodeur built-in "json" est utilisé.
     Ces décodeurs permettent de nommer la source dans les alertes. -->
<decoder name="flask-secureapp">
  <prematch>"event_type"</prematch>
</decoder>

<decoder name="nginx-secureapp">
  <prematch>"remote_addr"</prematch>
</decoder>
