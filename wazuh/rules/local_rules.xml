<!--
  ===========================================================================
  Règles de détection custom — SecureApp SIEM
  ===========================================================================

  Les règles custom commencent à partir de l'ID 100000.

  Niveaux Wazuh :
    0  = ignoré
    3  = info
    5  = avertissement
    7  = erreur / anomalie
    9  = attaque probable
    10 = attaque confirmée
    12 = critique / haute sévérité

  Architecture des décodeurs Wazuh 4.x avec log_format=json :
  - Le décodeur built-in "json" parse tous les champs JSON et les expose SANS préfixe data.
  - Les logs Flask (event_type présent) sont capturés par la règle Suricata 86600
    qui utilise decoded_as=json + field event_type.
  - Nos règles chaînent depuis 86600 et filtrent par message=auth_event (unique à Flask).
  - Les champs JSON sont accessibles SANS préfixe data. dans les règles (ex: event_type, ip, user).
  ===========================================================================
-->

<group name="secureapp,authentication,">

  <!-- ======================================================================
       RÈGLE PARENTE — Événement Flask détecté
       Chain depuis la règle Suricata 86600 (json + event_type présent).
       Le champ "message"="auth_event" est propre aux logs Flask.
  ======================================================================= -->
  <rule id="100000" level="0">
    <if_sid>86600</if_sid>
    <description>SecureApp Flask : événement d'authentification détecté</description>
    <group>authentication</group>
  </rule>

  <!-- ======================================================================
       RÈGLE 100001 — Échec de connexion (mot de passe incorrect)
       Niveau 5 : anomalie, pas encore une attaque
  ======================================================================= -->
  <rule id="100001" level="5">
    <if_sid>100000</if_sid>
    <field name="event_type">^login_fail$</field>
    <description>SecureApp : échec de connexion pour $(user) depuis $(ip)</description>
    <group>authentication_failed,pci_dss_10.2.4,gdpr_IV_35.7.d</group>
  </rule>

  <!-- ======================================================================
       RÈGLE 100002 — Connexion réussie
       Niveau 3 : info, utile pour l'audit
  ======================================================================= -->
  <rule id="100002" level="3">
    <if_sid>100000</if_sid>
    <field name="event_type">^login_success$</field>
    <description>SecureApp : connexion réussie pour $(user) depuis $(ip)</description>
    <group>authentication_success,pci_dss_10.2.5</group>
  </rule>

  <!-- ======================================================================
       RÈGLE 100003 — BRUTE FORCE LOGIN
       Déclenchée si la règle 100001 (login_fail) se produit
       plus de 5 fois en 60 secondes depuis la même IP source.
       Niveau 10 : attaque confirmée → active response déclenché
  ======================================================================= -->
  <rule id="100003" level="10" frequency="5" timeframe="60">
    <if_matched_sid>100001</if_matched_sid>
    <same_field>ip</same_field>
    <description>SecureApp : BRUTE FORCE DÉTECTÉ — $(frequency) tentatives depuis $(ip) en 60s</description>
    <group>authentication_failures,pci_dss_11.4,brute_force</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- ======================================================================
       RÈGLE 100004 — Échec de vérification MFA
       Niveau 7 : erreur / suspect
  ======================================================================= -->
  <rule id="100004" level="7">
    <if_sid>100000</if_sid>
    <field name="event_type">^mfa_fail$</field>
    <description>SecureApp : échec MFA pour $(user) depuis $(ip)</description>
    <group>authentication_failed,mfa</group>
  </rule>

  <!-- ======================================================================
       RÈGLE 100005 — MFA BYPASS ATTEMPT
       Déclenchée si la règle 100004 (mfa_fail) se produit
       plus de 3 fois en 5 minutes pour le même utilisateur.
       Niveau 12 : critique → tentative de contournement du MFA
  ======================================================================= -->
  <rule id="100005" level="12" frequency="3" timeframe="300">
    <if_matched_sid>100004</if_matched_sid>
    <same_field>user</same_field>
    <description>SecureApp : TENTATIVE DE BYPASS MFA — $(frequency) échecs pour $(user) en 5 min</description>
    <group>authentication_failures,mfa_bypass</group>
    <mitre>
      <id>T1621</id>
    </mitre>
  </rule>

  <!-- ======================================================================
       RÈGLE 100006 — Compte verrouillé (lockout)
       Niveau 9 : attaque probable (conséquence d'un brute force)
  ======================================================================= -->
  <rule id="100006" level="9">
    <if_sid>100000</if_sid>
    <field name="event_type">^account_locked$</field>
    <description>SecureApp : compte $(user) verrouillé suite à trop de tentatives depuis $(ip)</description>
    <group>account_lockout,pci_dss_8.1.6</group>
  </rule>

</group>


<group name="secureapp,web,injection,">

  <!-- ======================================================================
       RÈGLE PARENTE — Requête Nginx détectée
       Les logs Nginx ont "remote_addr" mais pas "event_type" → pas capturés par 86600.
       On utilise decoded_as=json + remote_addr comme discriminant.
  ======================================================================= -->
  <rule id="100010" level="0">
    <decoded_as>json</decoded_as>
    <field name="remote_addr">\.+</field>
    <description>SecureApp Nginx : requête HTTP reçue</description>
  </rule>

  <!-- ======================================================================
       RÈGLE 100011 — Détection SQLi (SQL Injection)
       Niveau 9 : attaque probable
  ======================================================================= -->
  <rule id="100011" level="9">
    <if_sid>100010</if_sid>
    <field name="uri" type="pcre2">(?i)(union(?:\s|%20|\+)+select|select(?:\s|%20|\+)+.+(?:\s|%20|\+)+from|insert(?:\s|%20|\+)+into|drop(?:\s|%20|\+)+table|--|xp_cmdshell|exec\s*\(|%27|%22.*or|or(?:\s|%20|\+)+1=1)</field>
    <description>SecureApp : TENTATIVE SQLi détectée depuis $(remote_addr) — URI : $(uri)</description>
    <group>sql_injection,pci_dss_6.5.1,web_attack</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <!-- ======================================================================
       RÈGLE 100012 — Détection XSS (Cross-Site Scripting)
       Niveau 9 : attaque probable
  ======================================================================= -->
  <rule id="100012" level="9">
    <if_sid>100010</if_sid>
    <field name="uri" type="pcre2">(?i)(%3Cscript|javascript:|onerror=|onload=|onclick=|alert\s*\(|document\.cookie|\.innerHTML|eval\s*\(|%3Csvg|%3Cimg)</field>
    <description>SecureApp : TENTATIVE XSS détectée depuis $(remote_addr) — URI : $(uri)</description>
    <group>xss,pci_dss_6.5.7,web_attack</group>
    <mitre>
      <id>T1059.007</id>
    </mitre>
  </rule>

  <!-- ======================================================================
       RÈGLE 100013 — Détection Path Traversal / LFI
       Niveau 9 : attaque probable
  ======================================================================= -->
  <rule id="100013" level="9">
    <if_sid>100010</if_sid>
    <field name="uri" type="pcre2">(?i)(\.\.\/|\.\.\\|%2e%2e%2f|%2e%2e\/|\/etc\/passwd|\/etc\/shadow|\/proc\/self|\.\.%2f)</field>
    <description>SecureApp : TENTATIVE PATH TRAVERSAL depuis $(remote_addr) — URI : $(uri)</description>
    <group>path_traversal,web_attack</group>
    <mitre>
      <id>T1083</id>
    </mitre>
  </rule>

  <!-- ======================================================================
       RÈGLE 100014 — Erreur 429 (Rate Limit atteint par Nginx)
       Niveau 7 : suspect, peut indiquer un scan ou attaque
  ======================================================================= -->
  <rule id="100014" level="7">
    <if_sid>100010</if_sid>
    <match>429</match>
    <description>SecureApp : rate limit Nginx atteint par $(remote_addr) sur $(uri)</description>
    <group>rate_limiting,web_attack</group>
  </rule>

  <!-- ======================================================================
       RÈGLE 100017 — Erreur HTTP 404 Nginx (niveau bas, source de comptage)
       Requête Nginx aboutissant à une ressource inexistante.
       Niveau 3 : info — sert de source pour la règle de fréquence 100015.
       Note : if_matched_sid sur une règle level-0 ne fonctionne pas dans
       Wazuh (les level-0 ne sont pas inclus dans le buffer de corrélation).
       Cette règle intermédiaire level-3 résout le problème.
  ======================================================================= -->
  <rule id="100017" level="3">
    <if_sid>100010</if_sid>
    <match type="pcre2">"status":40\d</match>
    <description>SecureApp Nginx : erreur HTTP 4xx depuis $(remote_addr) sur $(uri)</description>
    <group>web_4xx</group>
  </rule>

  <!-- ======================================================================
       RÈGLE 100015 — SCAN DE PORTS / ÉNUMÉRATION WEB
       Déclenchée si plus de 15 erreurs 404 depuis la même IP en 30 secondes.
       Niveau 10 : attaque confirmée
       Dépend de 100017 (level 3) comme source — if_matched_sid ne fonctionne
       pas avec des règles level-0.
  ======================================================================= -->
  <rule id="100015" level="10" frequency="15" timeframe="30">
    <if_matched_sid>100017</if_matched_sid>
    <same_field>remote_addr</same_field>
    <description>SecureApp : SCAN / ÉNUMÉRATION DÉTECTÉ — $(frequency) erreurs 404 depuis $(remote_addr) en 30s</description>
    <group>web_scan,enumeration</group>
    <mitre>
      <id>T1595.003</id>
    </mitre>
  </rule>

  <!-- ======================================================================
       RÈGLE 100018 — Requête Nginx sur /auth/login (intermédiaire level-3)
       Même raison que 100017 : if_matched_sid ne compte pas les level-0.
  ======================================================================= -->
  <rule id="100018" level="3">
    <if_sid>100010</if_sid>
    <field name="uri">^/auth/login</field>
    <description>SecureApp Nginx : requête sur /auth/login depuis $(remote_addr)</description>
    <group>web_auth</group>
  </rule>

  <!-- ======================================================================
       RÈGLE 100016 — ATTAQUE EN MASSE (brute force HTTP)
       Déclenchée si plus de 50 requêtes sur /auth/login
       depuis la même IP en 60 secondes.
       Niveau 12 : critique
  ======================================================================= -->
  <rule id="100016" level="12" frequency="50" timeframe="60">
    <if_matched_sid>100018</if_matched_sid>
    <same_field>remote_addr</same_field>
    <description>SecureApp : ATTAQUE BRUTE FORCE HTTP — $(frequency) requêtes sur /auth/login depuis $(remote_addr)</description>
    <group>brute_force,web_attack,pci_dss_11.4</group>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

</group>
